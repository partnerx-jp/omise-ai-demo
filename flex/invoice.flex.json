          { "type": "box", "layout": "horizontal", "contents": [ { "type": "text", "text": "品目", "size": "sm", "color": "#8c8c8c", "flex": 4 }, { "type": "text", "text": "強力粉 25kg×20袋 ほか", "size": "sm", "align": "end", "flex": 6, "wrap": true } ]},
          { "type": "box", "layout": "horizontal", "contents": [ { "type": "text", "text": "税込金額", "size": "sm", "color": "#8c8c8c", "flex": 4 }, { "type": "text", "text": "¥133,920", "size": "md", "weight": "bold", "color": "#2E7D32", "align": "end", "flex": 6 } ]},
          { "type": "separator", "margin": "md" },
          { "type": "box", "layout": "horizontal", "margin": "md", "contents": [ { "type": "text", "text": "税区分", "size": "sm", "color": "#8c8c8c", "flex": 4 }, { "type": "text", "text": "軽減税率8%（食品仕入）", "size": "sm", "align": "end", "flex": 6 } ]},
          { "type": "box", "layout": "horizontal", "contents": [ { "type": "text", "text": "勘定科目", "size": "sm", "color": "#8c8c8c", "flex": 4 }, { "type": "text", "text": "仕入高（原材料）", "size": "sm", "align": "end", "flex": 6 } ]},
          { "type": "box", "layout": "horizontal", "contents": [ { "type": "text", "text": "支払期日", "size": "sm", "color": "#8c8c8c", "flex": 4 }, { "type": "text", "text": "2026/8/31", "size": "sm", "align": "end", "flex": 6 } ]},
          { "type": "box", "layout": "horizontal", "contents": [ { "type": "text", "text": "メモ", "size": "sm", "color": "#8c8c8c", "flex": 4 }, { "type": "text", "text": "8月分 小麦粉仕入（3店舗共通）", "size": "sm", "align": "end", "flex": 6, "wrap": true } ]},
          { "type": "box", "layout": "vertical", "margin": "md", "paddingAll": "12px", "backgroundColor": "#f5f7f5", "cornerRadius": "8px", "contents": [
            { "type": "text", "text": "💬 AIが金額・税区分（軽減8%）・勘定科目まで判定しました。「登録」でfreee起票＋Google Drive保存（経理>請求書>2026年7月）まで自動で完了します。", "size": "xs", "color": "#555555", "wrap": true }
          ]}
        ]
      },
      "footer": {
        "type": "box", "layout": "vertical", "spacing": "sm", "paddingAll": "12px",
        "contents": [
          { "type": "button", "style": "primary", "color": "#1DB446", "height": "sm", "action": { "type": "postback", "label": "✅ この内容で登録", "data": "demo=invoice&act=done", "displayText": "この内容で登録して" } },
          { "type": "button", "style": "secondary", "height": "sm", "action": { "type": "uri", "label": "✏️ 編集する", "uri": "{{liff_invoice_url}}" } },
          { "type": "button", "style": "link", "height": "sm", "action": { "type": "uri", "label": "🔍 あなたのお店の数字で見る（無料診断）", "uri": "{{liff_shindan_url}}" } }
        ]
      }
