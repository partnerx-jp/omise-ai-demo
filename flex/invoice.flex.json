        "contents": [
          { "type": "text", "text": "🧾 請求書を読み取りました", "color": "#ffffff", "weight": "bold", "size": "md" },
          { "type": "text", "text": "この内容で登録していいですか？", "color": "#e8f5e9", "size": "xxs", "margin": "sm" }
