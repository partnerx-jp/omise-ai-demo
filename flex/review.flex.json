        { "type": "box", "layout": "vertical", "paddingStart": "16px", "paddingEnd": "16px", "paddingTop": "14px", "paddingBottom": "12px", "contents": [
          { "type": "text", "text": "{{date_ja}}", "size": "xs", "color": "#888888" },
          { "type": "text", "text": "⭐ 新しい口コミが届きました", "size": "md", "weight": "bold", "color": "#1A1A1A", "margin": "sm" },
