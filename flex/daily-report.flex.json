    "footer": {
      "type": "box",
      "layout": "vertical",
      "spacing": "sm",
      "paddingAll": "12px",
      "contents": [
        {
          "type": "button",
          "style": "primary",
          "color": "#1DB446",
          "height": "sm",
          "action": { "type": "uri", "label": "詳しく見る（分析グラフ）", "uri": "{{liff_daily_url}}" }
        },
        {
          "type": "button",
          "style": "link",
          "height": "sm",
          "action": { "type": "uri", "label": "🔍 あなたのお店の数字で見る（無料診断）", "uri": "{{liff_shindan_url}}" }
        }
      ]
    }
  }
}
